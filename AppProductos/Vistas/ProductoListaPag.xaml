<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"           
             xmlns:models="clr-namespace:EsquemaMAUI.Esquemas;assembly=EsquemaMAUI"
             x:Class="AppProductos.Vistas.ProductoListaPage"
             Title="Inventario BralDev">
    <Grid RowDefinitions="Auto, *, Auto">

        <Label Grid.Row="0"
               Text="{Binding pcMensaje}"
               IsVisible="{Binding pbHayError}"
               TextColor="Red"
               HorizontalOptions="Center"
               Margin="10"/>

        <RefreshView Grid.Row="1"
             IsRefreshing="{Binding IsRefreshing}"
             Command="{Binding CargarProductosCommand}">

            <CollectionView ItemsSource="{Binding paProductos}"
                            SelectionMode="Single"
                            SelectionChanged="OnProductoSeleccionado">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProductoListaModel">

                        <!-- Border reemplaza a Frame -->
                        <Border Margin="10,5" Padding="15" StrokeShape="RoundRectangle 10">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="2,2" Radius="4" Opacity="0.2"/>
                            </Border.Shadow>

                            <!-- Grid reemplaza HorizontalStackLayout con EndAndExpand -->
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="{Binding pcNomPro}"
                                           FontSize="18"
                                           FontAttributes="Bold"/>
                                    <Label Text="{Binding pcDesPro}"
                                           FontSize="14"
                                           TextColor="Gray"/>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding pnPrePro, StringFormat='S/ {0:F2}'}"
                                           FontAttributes="Bold"
                                           HorizontalOptions="End"/>
                                    <Label Text="{Binding pnStoPro, StringFormat='Stock: {0}'}"
                                           FontSize="12"
                                           HorizontalOptions="End"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button Grid.Row="2"
                Text="+ Nuevo Producto"
                Clicked="OnAgregarProductoClick"
                Margin="20"
                BackgroundColor="#2196F3"
                TextColor="White"
                CornerRadius="25"
                HeightRequest="50"/>
    </Grid>
</ContentPage>